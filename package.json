{
  "name": "astrofy",
  "description": "Astrofy is a free and open-source template for your Personal Portfolio Website built with Astro and TailwindCSS. Create in minutes a website with Blog, CV, Project Section, Store and RSS Feed.",
  "type": "module",
  "version": "3.0.0",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS='--max-http-header-size=32768' astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "format:check": "prettier --check .",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/mdx": "^2.0.3",
    "@astrojs/rss": "^3.0.0",
    "@astrojs/sitemap": "^3.0.1",
    "@astrojs/tailwind": "^5.0.3",
    "@fontsource-variable/noto-serif-sc": "^5.2.5",
    "@fontsource-variable/nunito": "^5.2.5",
    "@fontsource/m-plus-rounded-1c": "^5.2.10",
    "@mogeko/maple-mono-cn": "^7.9.0",
    "astro": "^4.0.2",
    "daisyui": "^4.4.10",
    "dayjs": "^1.11.9",
    "harmonyos-sans-sc-webfont-splitted": "^1.1.0",
    "lucide": "^0.479.0",
    "lxgw-wenkai-webfont": "^1.7.0",
    "rehype-katex": "^7.0.1",
    "remark-math": "^6.0.0",
    "sharp": "^0.32.6",
    "tailwindcss": "^3.3.5"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.10",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1"
  }
}
