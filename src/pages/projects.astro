---
import BaseLayout from "../layouts/BaseLayout.astro";
import HorizontalCard from "../components/HorizontalCard.astro";
import { AUTHOR_INITIAL, url } from "src/config";
---

<BaseLayout
    title={AUTHOR_INITIAL + " | Projects"}
    sideBarActiveItemID="projects"
>
    <div>
        <div class="text-3xl w-full font-bold mb-5">Projects</div>
    </div>

    <div class="divider my-0"></div>
    <HorizontalCard
        title="Your Project"
        img={url('post_img.png')}
        desc="Add your project description here."
        url="#"
        badge="demo"
    />
