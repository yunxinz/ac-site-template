---
import { url } from "../config";
const { sideBarActiveItemID } = Astro.props;
const activeClass = "bg-ac-primary/15 text-ac-primary-dark rounded-ac-md";
---

<ul class="menu grow shrink menu-md overflow-y-auto">
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="home"
            href={url('')}
        >
            <img src={url('nookmiles.png')} alt="" class="w-6 h-6 rounded-ac-sm" />
            Home
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="projects"
            href={url('projects')}
        >
            <img src={url('brush.png')} alt="" class="w-6 h-6 rounded-ac-sm" />
            Projects
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="cv"
            href={url('cv')}
        >
            <img src={url('nookwallet.png')} alt="" class="w-6 h-6 rounded-ac-sm" />
            CV
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="blog"
            href={url('blog/')}
        >
            <img src={url('photos.png')} alt="" class="w-6 h-6 rounded-ac-sm" />
            Blog
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="personal"
            href={url('personal')}
        >
            <img src={url('nookcritters.png')} alt="" class="w-6 h-6 rounded-ac-sm" />
            Personal
        </a>
    </li>
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            id="notes"
            href={url('notes')}
        >
            <img src={url('drawing.png')} alt="" class="w-6 h-6 rounded-ac-sm" />
            Notes
        </a>
    </li>
    <!-- <li><a class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand" id="store" href="/store"><img src="/nookstore.png" alt="" class="w-6 h-6 rounded-ac-sm" />Store</a></li> -->
    <li>
        <a
            class="py-3 text-base rounded-ac-md transition-colors hover:bg-ac-sand"
            href="mailto:your@email.com"
            target="_blank"
            referrerpolicy="no-referrer-when-downgrade"
        >
            <img src={url('messages.png')} alt="" class="w-6 h-6 rounded-ac-sm" />
            Contact
        </a>
    </li>
</ul>

<script
    define:vars={{
        sideBarActiveItemID: sideBarActiveItemID,
        activeClass: activeClass,
    }}
>
    const activeItemElem = document.getElementById(sideBarActiveItemID);
    activeItemElem && activeItemElem.classList.add(activeClass);
</script>
